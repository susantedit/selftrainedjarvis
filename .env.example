# =============================================================================
# J.A.R.V.I.S — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to git — it contains your private API keys.
# =============================================================================


# ==============================
# GROQ API — REQUIRED
# ==============================
# Get your free key at https://console.groq.com
# Without this, the AI will not work at all.

GROQ_API_KEY=your_groq_api_key_here

# Optional: add more keys for automatic fallback when rate limit is hit.
# Free tier has daily limits — more keys = more capacity.
# GROQ_API_KEY_2=your_second_key_here
# GROQ_API_KEY_3=your_third_key_here


# ==============================
# TAVILY API — OPTIONAL
# ==============================
# Required only for Realtime/web search mode.
# Get your free key at https://tavily.com
# If not set, Jarvis will skip web search and answer from knowledge only.

# TAVILY_API_KEY=your_tavily_api_key_here


# ==============================
# GROQ MODELS — OPTIONAL
# ==============================
# Main chat model (70B = smarter, slower | 8B = faster, lighter)
GROQ_MODEL=llama-3.3-70b-versatile

# Brain/classifier model — used for intent detection (keep fast)
GROQ_BRAIN_MODEL=llama-3.1-8b-instant

# Intent classifier model
INTENT_CLASSIFY_MODEL=llama-3.1-8b-instant

# Vision model — used when you send a camera image
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct


# ==============================
# TEXT-TO-SPEECH — OPTIONAL
# ==============================
# Uses Microsoft Edge TTS — no API key needed, completely free.
# Run  edge-tts --list-voices  to see all available voices.

# Voice examples:
#   en-GB-RyanNeural        (British male — default, JARVIS-style)
#   en-US-ChristopherNeural (US male)
#   en-US-JennyNeural       (US female)
#   en-IN-NeerjaNeural      (Indian English female)
#   hi-IN-MadhurNeural      (Hindi male)

TTS_VOICE=en-GB-RyanNeural

# Speed: +0% = normal, +22% = slightly faster (default), -10% = slower
TTS_RATE=+22%


# ==============================
# ASSISTANT IDENTITY — OPTIONAL
# ==============================
# Customize how the AI refers to itself and addresses you.

# Name shown in the UI and used in responses. Default: Jarvis
ASSISTANT_NAME=Jarvis

# How the AI addresses you (e.g. Sir, Boss). Leave blank to skip.
# JARVIS_USER_TITLE=Sir

# Your name — so the AI knows who it belongs to.
# JARVIS_OWNER_NAME=Your Name


# ==============================
# TIMEOUTS — OPTIONAL
# ==============================
# How long (seconds) to wait for task execution and Groq API calls.

TASK_EXECUTION_TIMEOUT=30
GROQ_REQUEST_TIMEOUT=30
